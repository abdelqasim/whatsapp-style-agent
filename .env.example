# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── WhatsApp Business API ────────────────────────────────────────────────────
# From Meta Developer Dashboard → WhatsApp → API Setup
WHATSAPP_TOKEN=your_whatsapp_system_user_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=any_string_you_choose_for_verification
ADMIN_PHONE_NUMBER=your_phone_number_no_plus_sign

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost                   # Use 'qdrant' when running inside Docker Compose
QDRANT_PORT=6333

# ─── n8n ──────────────────────────────────────────────────────────────────────
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=change_this_to_a_random_32_char_string
# Public HTTPS URL exposing the n8n webhook to Meta
# For local development: use Cloudflare Tunnel (cloudflared tunnel --url http://localhost:5678)
# For production: use your server's domain
WEBHOOK_URL=https://your-tunnel-url.trycloudflare.com

# ─── Google Calendar ──────────────────────────────────────────────────────────
# Download from Google Cloud Console → APIs → Credentials → OAuth 2.0 Client IDs
GOOGLE_CALENDAR_CREDENTIALS=./data/google_credentials.json
# Calendar to create events on ('primary' = your main calendar)
GOOGLE_CALENDAR_ID=primary

# ─── Backend ──────────────────────────────────────────────────────────────────
# Used by n8n workflows to call the Python backend
# Inside Docker Compose: http://backend:8000
# Outside Docker (local dev): http://localhost:8000
BACKEND_URL=http://backend:8000
